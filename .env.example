# --- Athena Web (Elixir App) ---
# Generate a new secret with: mix phx.gen.secret
SECRET_KEY_BASE=generate_your_long_secret_string_here
PHX_HOST=athena.example.com
PORT=4000
# DATABASE_URL matches the postgres credentials below
DATABASE_URL=ecto://athena_prod_user:StrongDBPassword!@postgres:5432/athena_prod
POOL_SIZE=10

# --- PostgreSQL ---
POSTGRES_USER=athena_prod_user
POSTGRES_PASSWORD=StrongDBPassword!
POSTGRES_DB=athena_prod

# --- MinIO (S3 Storage) ---
# Used to initialize the MinIO server
MINIO_ROOT_USER=athena_admin
MINIO_ROOT_PASSWORD=StrongMinioPassword!

# Used by the Elixir App (ex_aws) to connect to MinIO
MINIO_ACCESS_KEY=athena_admin
MINIO_SECRET_KEY=StrongMinioPassword!
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_SCHEME=http://
MINIO_BUCKET=athena