<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Athena" suffix=" · LMS">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="h-full antialiased overflow-x-hidden">
    <div class="browser-support-banner bg-warning text-warning-content sticky top-0 z-[9999] px-4 py-2 flex flex-col sm:flex-row items-center justify-center gap-2 text-sm font-bold shadow-md">
      <.icon name="hero-exclamation-triangle" class="size-5 shrink-0" />
      <span class="text-center">
        {gettext(
          "Your browser is out of date. Athena LMS may not display correctly. Please update your browser for the best experience."
        )}
      </span>
      <button
        onclick="this.parentElement.style.display='none'"
        class="btn btn-ghost btn-xs btn-circle ml-auto sm:ml-4"
        aria-label={gettext("Dismiss")}
      >
        <.icon name="hero-x-mark" class="size-4" />
      </button>
    </div>
    {@inner_content}
  </body>
</html>
